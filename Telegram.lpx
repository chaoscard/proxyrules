#!name=Telegram增强
#!desc=将Telegram的垃圾IP转移到好的IP上，减少转圈加载；Telegram外部链接跳转至第三方客户端
#!openUrl=https://apps.apple.com/app/id686449807
#!homepage=https://github.com/chaoscard/proxyrules
#!author=chaoscard[https://github.com/chaoscard], sooyaaabo[https://github.com/sooyaaabo], Repcz[https://github.com/Repcz/Tool]
#!tag=功能增强
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/Telegram.png
#!date=2026-04-11

[Argument]
t.me_redirect=select, "Telegram", "Swiftgram", "Turrit", "iMe", "Nicrgram", "Lingogram", tag=跳转至对应客户端

[Host]
91.108.56.100 = 91.108.56.147, use-in-proxy=true
